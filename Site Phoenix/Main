local drawingPropCache = {}
local function setDrawingProp(drawing, prop, value)
    if not drawingPropCache[drawing] then
        drawingPropCache[drawing] = {}
    end
    if drawingPropCache[drawing][prop] ~= value then
        drawingPropCache[drawing][prop] = value
        drawing[prop] = value
    end
end

