local function hideVisuals(data)
    for i = 1, 14 do setDrawingProp(data.Skeleton[i], "Visible", false) end
    for i = 1, 8 do setDrawingProp(data.CornerBox[i], "Visible", false) end
    setDrawingProp(data.Box, "Visible", false)
    setDrawingProp(data.HealthBarBg, "Visible", false)
    setDrawingProp(data.HealthBar, "Visible", false)
    setDrawingProp(data.NameTag, "Visible", false)
    setDrawingProp(data.DistanceTag, "Visible", false)
    setDrawingProp(data.HealthTextTag, "Visible", false)
    setDrawingProp(data.ToolTag, "Visible", false)
end

local function validateCache(entity, data, isNPC)
    local character = isNPC and entity or entity.Character
    if not character then
        data.CachedParts = nil
        return nil
    end

    if data.CachedParts and data.CachedParts.Character == character and data.CachedParts.HRP and data.CachedParts.HRP.Parent and data.CachedParts.Humanoid and data.CachedParts.Humanoid.Parent then
        return data.CachedParts
    end

    local hrp = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    local humanoid = character:FindFirstChild("Humanoid") or character:FindFirstChildOfClass("Humanoid")

    if not hrp or not humanoid then
        data.CachedParts = nil
        return nil
    end

    local isR15 = character:FindFirstChild("UpperTorso") ~= nil
    local currentBones = isR15 and R15_BONES or R6_BONES
    local boneParts = {}

    for i, bonePair in ipairs(currentBones) do
        boneParts[i] = {
            character:FindFirstChild(bonePair[1]),
            character:FindFirstChild(bonePair[2])
        }
    end

    data.CachedParts = {
        HRP = hrp,
        Humanoid = humanoid,
        BoneParts = boneParts,
        Character = character
    }

    return data.CachedParts
end

local function createESPData(cacheTable, key)
    if cacheTable[key] then return end

    local data = {
        Skeleton = {},
        CornerBox = {},
        Box = draw_new("Square"),
        HealthBarBg = draw_new("Square"),
        HealthBar = draw_new("Square"),
        NameTag = draw_new("Text"),
        DistanceTag = draw_new("Text"),
        HealthTextTag = draw_new("Text"),
        ToolTag = draw_new("Text"),
        CachedParts = nil,
        Connections = {}
    }

    setDrawingProp(data.Box, "Thickness", 1.5)
    setDrawingProp(data.Box, "Filled", false)
    setDrawingProp(data.Box, "Visible", false)

    setDrawingProp(data.HealthBarBg, "Color", c3rgb(40, 40, 40))
    setDrawingProp(data.HealthBarBg, "Filled", true)
    setDrawingProp(data.HealthBarBg, "Thickness", 0)
    setDrawingProp(data.HealthBarBg, "Visible", false)

    setDrawingProp(data.HealthBar, "Filled", true)
    setDrawingProp(data.HealthBar, "Thickness", 0)
    setDrawingProp(data.HealthBar, "Visible", false)

    setDrawingProp(data.NameTag, "Size", 13)
    setDrawingProp(data.NameTag, "Center", true)
    setDrawingProp(data.NameTag, "Outline", true)
    setDrawingProp(data.NameTag, "Visible", false)

    setDrawingProp(data.DistanceTag, "Size", 13)
    setDrawingProp(data.DistanceTag, "Center", true)
    setDrawingProp(data.DistanceTag, "Outline", true)
    setDrawingProp(data.DistanceTag, "Visible", false)
    
    setDrawingProp(data.HealthTextTag, "Size", 13)
    setDrawingProp(data.HealthTextTag, "Center", true)
    setDrawingProp(data.HealthTextTag, "Outline", true)
    setDrawingProp(data.HealthTextTag, "Visible", false)
    
    setDrawingProp(data.ToolTag, "Size", 13)
    setDrawingProp(data.ToolTag, "Center", true)
    setDrawingProp(data.ToolTag, "Outline", true)
    setDrawingProp(data.ToolTag, "Visible", false)

    for i = 1, 14 do
        local line = draw_new("Line")
        setDrawingProp(line, "Thickness", 1.5)
        setDrawingProp(line, "Visible", false)
        t_insert(data.Skeleton, line)
    end
    
    for i = 1, 8 do
        local line = draw_new("Line")
        setDrawingProp(line, "Thickness", 1.5)
        setDrawingProp(line, "Visible", false)
        t_insert(data.CornerBox, line)
    end

    cacheTable[key] = data
end

local function removeESPData(cacheTable, key)
    if cacheTable[key] then
        local data = cacheTable[key]
        for _, conn in ipairs(data.Connections) do
            conn:Disconnect()
        end
        for i = 1, 14 do data.Skeleton[i]:Remove() end
        for i = 1, 8 do data.CornerBox[i]:Remove() end
        data.Box:Remove()
        data.HealthBarBg:Remove()
        data.HealthBar:Remove()
        data.NameTag:Remove()
        data.DistanceTag:Remove()
        data.HealthTextTag:Remove()
        data.ToolTag:Remove()
        drawingPropCache[data.Box] = nil
        drawingPropCache[data.HealthBarBg] = nil
        drawingPropCache[data.HealthBar] = nil
        drawingPropCache[data.NameTag] = nil
        drawingPropCache[data.DistanceTag] = nil
        drawingPropCache[data.HealthTextTag] = nil
        drawingPropCache[data.ToolTag] = nil
        cacheTable[key] = nil
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then createESPData(ESPCache, player) end
end

t_insert(Connections, Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer then createESPData(ESPCache, player) end
end))

t_insert(Connections, Players.PlayerRemoving:Connect(function(player)
    removeESPData(ESPCache, player)
end))

if scpHumanoids then
    for _, npc in ipairs(scpHumanoids:GetChildren()) do
        if npc:IsA("Model") then createESPData(NPC_ESPCache, npc) end
    end
    t_insert(Connections, scpHumanoids.ChildAdded:Connect(function(child)
        if child:IsA("Model") then createESPData(NPC_ESPCache, child) end
    end))
    t_insert(Connections, scpHumanoids.ChildRemoved:Connect(function(child)
        removeESPData(NPC_ESPCache, child)
    end))
end

local function isHoldingPrioritizedWeapon(character)
    local tool = character:FindFirstChildOfClass("Tool")
    if not tool then return false end
    
    local weaponShopAssets = ReplicatedStorage:FindFirstChild("WeaponShopAssets")
    if not weaponShopAssets then return false end
    
    local folders = {"Pistol", "Rifle", "SMG", "Shotgun"}
    for _, folderName in ipairs(folders) do
        local folder = weaponShopAssets:FindFirstChild(folderName)
        if folder and folder:FindFirstChild(tool.Name) then
            return true
        end
    end
    
    return false
end

local function getClosestCharacterToMouse(mousePos, currentCamera)
    if not currentCamera then return nil, nil, nil, false end

    local fovEnabled = Toggles and Toggles.FOVEnabled and Toggles.FOVEnabled.Value
    local fovRadiusSq = Options and Options.FOVRadius and (Options.FOVRadius.Value * Options.FOVRadius.Value) or 10000
    local visibleCheck = Toggles and Toggles.VisibleCheck and Toggles.VisibleCheck.Value
    local teamCheck = Toggles and Toggles.TeamCheck and Toggles.TeamCheck.Value
    local ignoredTeams = Options and Options.IgnoredTeams and Options.IgnoredTeams.Value or {}
    
    local targetPlayers = Toggles and Toggles.SilentAimEnabled and Toggles.SilentAimEnabled.Value
    local targetNPCsToggle = Toggles and Toggles.NPCSilentAimEnabled and Toggles.NPCSilentAimEnabled.Value

    if not targetPlayers and not targetNPCsToggle then
        return nil, nil, nil, false
    end

    local localChar = LocalPlayer.Character
    if lastRaycastCamera ~= currentCamera or lastRaycastCharacter ~= localChar then
        lastRaycastCamera = currentCamera
        lastRaycastCharacter = localChar
        local filter = {currentCamera}
        if localChar then
            t_insert(filter, localChar)
        end
        local debrisFolder = Workspace:FindFirstChild("Debris")
        if debrisFolder then
            local rayExceptionFolder = debrisFolder:FindFirstChild("RayException")
            if rayExceptionFolder then
                t_insert(filter, rayExceptionFolder)
            end
        end
        sharedRaycastParams.FilterDescendantsInstances = filter
    end
    
    local camCFramePos = currentCamera.CFrame.Position
    local potentialTargets = {}
    local entities = {}

    if targetPlayers then
        for player, data in pairs(ESPCache) do
            local cached = validateCache(player, data, false)
            if cached and cached.Humanoid and cached.Humanoid.Health > 0 then
                if teamCheck and player.Team and ignoredTeams[player.Team.Name] then continue end
                t_insert(entities, {
                    character = cached.Character,
                    head = cached.Character:FindFirstChild("Head"),
                    hrp = cached.HRP,
                    isNPC = false
                })
            end
        end
    end

    if targetNPCsToggle then
        local targetNPCs = Options and Options.TargetNPCs and Options.TargetNPCs.Value or {}
        for npc, data in pairs(NPC_ESPCache) do
            if targetNPCs[npc.Name] then
                local cached = validateCache(npc, data, true)
                if cached and cached.Humanoid and cached.Humanoid.Health > 0 then
                    t_insert(entities, {
                        character = cached.Character,
                        head = cached.Character:FindFirstChild("Head"),
                        hrp = cached.HRP,
                        isNPC = true
                    })
                end
            end
        end
    end

    local now = os.clock()
    for i = 1, #entities do
        local entity = entities[i]
        local targetPartName = entity.isNPC and (Options and Options.NPCHitpart and Options.NPCHitpart.Value or "HumanoidRootPart") or (Options and Options.Hitpart and Options.Hitpart.Value or "HumanoidRootPart")
        local targetPart
        
        if not TargetCache[entity.character] then
            TargetCache[entity.character] = { part = nil, lastUpdate = 0 }
        end
        
        local cache = TargetCache[entity.character]
        
        if now - cache.lastUpdate >= 0.5 or not cache.part or not cache.part.Parent then
            if targetPartName == 'Random' then
                local priorityPartName = Options and Options.PriorityPart and Options.PriorityPart.Value or "Head"
                local priorityChance = Options and Options.PriorityChance and Options.PriorityChance.Value or 0
                local priorityPart = entity.character:FindFirstChild(priorityPartName)
                
                if priorityPart and m_random(1, 100) <= priorityChance then
                    cache.part = priorityPart
                else
                    local parts = {}
                    for _, v in ipairs(entity.character:GetChildren()) do
                        if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" and v.Name ~= priorityPartName then
                            t_insert(parts, v)
                        end
                    end
                    if #parts > 0 then
                        cache.part = parts[m_random(1, #parts)]
                    elseif priorityPart then
                        cache.part = priorityPart
                    else
                        cache.part = entity.hrp
                    end
                end
            else
                cache.part = targetPartName == 'Head' and entity.head or entity.hrp
            end
            
            cache.lastUpdate = now
        end
        
        targetPart = cache.part
        if not targetPart then continue end

        local rootScreenPos, rootOnScreen = currentCamera:WorldToViewportPoint(targetPart.Position)
        if fovEnabled and rootOnScreen then
            local rootDistSq = (rootScreenPos.X - mousePos.X) * (rootScreenPos.X - mousePos.X) + (rootScreenPos.Y - mousePos.Y) * (rootScreenPos.Y - mousePos.Y)
            if rootDistSq > (fovRadiusSq * 3) then
                continue
            end
        end
        
        if Toggles and Toggles.MultipointEnabled and Toggles.MultipointEnabled.Value then
            local size = targetPart.Size * 0.8
            local cf = targetPart.CFrame
            local hx, hy, hz = size.X / 2, size.Y / 2, size.Z / 2
            
            local bestVisibleOffset = nil
            local bestVisibleDist = m_huge
            local bestInvisibleOffset = nil
            local bestInvisibleDist = m_huge
            
            for _, offset in ipairs(MULTIPOINT_OFFSETS) do
                local point = (cf * cf_new(hx * offset.X, hy * offset.Y, hz * offset.Z)).Position
                local screenPos, onScreen = currentCamera:WorldToViewportPoint(point)
                
                if onScreen then
                    local charPos2D = v2(screenPos.X, screenPos.Y)
                    local distSq = (charPos2D.X - mousePos.X) * (charPos2D.X - mousePos.X) + (charPos2D.Y - mousePos.Y) * (charPos2D.Y - mousePos.Y)
                    
                    if not fovEnabled or distSq <= fovRadiusSq then
                        local isVisible = true
                        local raycastResult = Workspace:Raycast(camCFramePos, point - camCFramePos, sharedRaycastParams)
                        if raycastResult and raycastResult.Instance and not raycastResult.Instance:IsDescendantOf(entity.character) then
                            isVisible = false
                        end
                        
                        if isVisible then
                            if distSq < bestVisibleDist then
                                bestVisibleDist = distSq
                                bestVisibleOffset = offset
                            end
                        else
                            if distSq < bestInvisibleDist then
                                bestInvisibleDist = distSq
                                bestInvisibleOffset = offset
                            end
                        end
                    end
                end
            end
            
            local finalOffset = bestVisibleOffset or bestInvisibleOffset
            if finalOffset then
                local distSq = bestVisibleOffset and bestVisibleDist or bestInvisibleDist
                local point = (cf * cf_new(hx * finalOffset.X, hy * finalOffset.Y, hz * finalOffset.Z)).Position
                local screenPos = currentCamera:WorldToViewportPoint(point)
                local charPos2D = v2(screenPos.X, screenPos.Y)
                
                t_insert(potentialTargets, {
                    distanceSq = distSq,
                    pos2D = charPos2D,
                    part = targetPart,
                    hitPos = point,
                    character = entity.character,
                    hasPriority = not entity.isNPC and isHoldingPrioritizedWeapon(entity.character),
                    isVisible = bestVisibleOffset ~= nil,
                    isNPC = entity.isNPC
                })
            end
        else
            local point = targetPart.Position
            local screenPos, onScreen = currentCamera:WorldToViewportPoint(point)
            
            if onScreen then
                local charPos2D = v2(screenPos.X, screenPos.Y)
                local distSq = (charPos2D.X - mousePos.X) * (charPos2D.X - mousePos.X) + (charPos2D.Y - mousePos.Y) * (charPos2D.Y - mousePos.Y)
                
                if not fovEnabled or distSq <= fovRadiusSq then
                    local isVisible = true
                    local raycastResult = Workspace:Raycast(camCFramePos, point - camCFramePos, sharedRaycastParams)
                    if raycastResult and raycastResult.Instance and not raycastResult.Instance:IsDescendantOf(entity.character) then
                        isVisible = false
                    end

                    t_insert(potentialTargets, {
                        distanceSq = distSq,
                        pos2D = charPos2D,
                        part = targetPart,
                        hitPos = point,
                        character = entity.character,
                        hasPriority = not entity.isNPC and isHoldingPrioritizedWeapon(entity.character),
                        isVisible = isVisible,
                        isNPC = entity.isNPC
                    })
                end
            end
        end
    end

    t_sort(potentialTargets, function(a, b)
        if a.isVisible and not b.isVisible then return true end
        if not a.isVisible and b.isVisible then return false end

        if Toggles and Toggles.PrioritizeArmed and Toggles.PrioritizeArmed.Value then
            if a.hasPriority and not b.hasPriority then return true end
            if not a.hasPriority and b.hasPriority then return false end
        end
        return a.distanceSq < b.distanceSq
    end)

    for i = 1, #potentialTargets do
        local target = potentialTargets[i]
        
        if visibleCheck and not target.isVisible then
            continue
        end
        
        return target.pos2D, target.part, target.hitPos, target.isNPC
    end
    
    return nil, nil, nil, false
end

local fullbrightConnection
local function updateFullbright()
    if Toggles and Toggles.Fullbright and Toggles.Fullbright.Value then
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.FogEnd = 100000
        Lighting.GlobalShadows = false
        Lighting.OutdoorAmbient = c3rgb(128, 128, 128)
    end
end

WorldGroup:AddToggle('Fullbright', { Text = 'Fullbright', Default = false }):OnChanged(function()
    if Toggles and Toggles.Fullbright and Toggles.Fullbright.Value then
        OriginalLighting.Brightness = Lighting.Brightness
        OriginalLighting.ClockTime = Lighting.ClockTime
        OriginalLighting.FogEnd = Lighting.FogEnd
        OriginalLighting.GlobalShadows = Lighting.GlobalShadows
        OriginalLighting.OutdoorAmbient = Lighting.OutdoorAmbient
        
        updateFullbright()
        fullbrightConnection = Lighting.Changed:Connect(updateFullbright)
    else
        if fullbrightConnection then
            fullbrightConnection:Disconnect()
            fullbrightConnection = nil
        end
        if OriginalLighting.Brightness then
            Lighting.Brightness = OriginalLighting.Brightness
            Lighting.ClockTime = OriginalLighting.ClockTime
            Lighting.FogEnd = OriginalLighting.FogEnd
            Lighting.GlobalShadows = OriginalLighting.GlobalShadows
            Lighting.OutdoorAmbient = OriginalLighting.OutdoorAmbient
        end
    end
end)

local function updateVisualsForCache(cacheTable, currentCamera, camPos, isNPC)
    local tggls = Toggles
    local opts = Options
    if not (tggls and opts) then return end

    local espEnabled, boxEnabled, skeletonEnabled, nameEnabled, distanceEnabled, healthEnabled, healthTextEnabled
    local boxColorVal, nameColorVal, skelColorVal, boxTypeVal
    
    local teamColorEnabled = not isNPC and tggls.ESPTeamColor.Value
    local toolEnabled = not isNPC and tggls.ESPTool.Value

    if isNPC then
        espEnabled = tggls.NPCESPEnabled.Value
        boxEnabled = tggls.NPCESPBox.Value
        skeletonEnabled = tggls.NPCESPSkeleton.Value
        nameEnabled = tggls.NPCESPName.Value
        distanceEnabled = tggls.NPCESPDistance.Value
        healthEnabled = tggls.NPCESPHealth.Value
        healthTextEnabled = tggls.NPCESPHealthText.Value
        
        boxColorVal = opts.NPCBoxColor.Value
        nameColorVal = opts.NPCNameColor.Value
        skelColorVal = opts.NPCSkeletonColor.Value
        boxTypeVal = opts.NPCESPBoxType.Value
    else
        espEnabled = tggls.ESPEnabled.Value
        boxEnabled = tggls.ESPBox.Value
        skeletonEnabled = tggls.ESPSkeleton.Value
        nameEnabled = tggls.ESPName.Value
        distanceEnabled = tggls.ESPDistance.Value
        healthEnabled = tggls.ESPHealth.Value
        healthTextEnabled = tggls.ESPHealthText.Value
        
        boxColorVal = opts.BoxColor.Value
        nameColorVal = opts.NameColor.Value
        skelColorVal = opts.SkeletonColor.Value
        boxTypeVal = opts.ESPBoxType.Value
    end

    if not espEnabled then
        for _, data in pairs(cacheTable) do hideVisuals(data) end
        return
    end
    
    local needsBox = boxEnabled or nameEnabled or distanceEnabled or healthEnabled or toolEnabled or healthTextEnabled

    for entity, data in pairs(cacheTable) do
        local cached = validateCache(entity, data, isNPC)
        if cached and cached.Humanoid.Health > 0 then
            local hrp = cached.HRP
            local humanoid = cached.Humanoid
            local character = cached.Character

            local hasTeamColor = false
            local espColor = c3new(1, 1, 1)
            if teamColorEnabled and entity.Team then
                espColor = entity.TeamColor.Color
                hasTeamColor = true
            end

            local currentBoxColor = hasTeamColor and espColor or boxColorVal
            local currentNameColor = hasTeamColor and espColor or nameColorVal
            local currentSkeletonColor = hasTeamColor and espColor or skelColorVal

            local topPos, bottomPos, onScreenTop, onScreenBottom
            local isBoxVisible = false

            if needsBox then
                topPos, onScreenTop = currentCamera:WorldToViewportPoint(hrp.Position + v3(0, 3.3, 0))
                bottomPos, onScreenBottom = currentCamera:WorldToViewportPoint(hrp.Position - v3(0, 4.2, 0))
                isBoxVisible = onScreenTop or onScreenBottom
            end

            if isBoxVisible then
                local boxHeight = m_abs(topPos.Y - bottomPos.Y)
                local boxWidth = boxHeight * 0.625
                local boxX = topPos.X - (boxWidth / 2)
                local boxY = topPos.Y

                if boxEnabled then
                    if boxTypeVal == 'Corner' then
                        setDrawingProp(data.Box, "Visible", false)
                        local lineW = boxWidth / 3
                        local lineH = boxHeight / 4
                        
                        data.CornerBox[1].From = v2(boxX, boxY)
                        data.CornerBox[1].To = v2(boxX + lineW, boxY)
                        data.CornerBox[2].From = v2(boxX, boxY)
                        data.CornerBox[2].To = v2(boxX, boxY + lineH)
                        
                        data.CornerBox[3].From = v2(boxX + boxWidth, boxY)
                        data.CornerBox[3].To = v2(boxX + boxWidth - lineW, boxY)
                        data.CornerBox[4].From = v2(boxX + boxWidth, boxY)
                        data.CornerBox[4].To = v2(boxX + boxWidth, boxY + lineH)
                        
                        data.CornerBox[5].From = v2(boxX, boxY + boxHeight)
                        data.CornerBox[5].To = v2(boxX + lineW, boxY + boxHeight)
                        data.CornerBox[6].From = v2(boxX, boxY + boxHeight)
                        data.CornerBox[6].To = v2(boxX, boxY + boxHeight - lineH)
                        
                        data.CornerBox[7].From = v2(boxX + boxWidth, boxY + boxHeight)
                        data.CornerBox[7].To = v2(boxX + boxWidth - lineW, boxY + boxHeight)
                        data.CornerBox[8].From = v2(boxX + boxWidth, boxY + boxHeight)
                        data.CornerBox[8].To = v2(boxX + boxWidth, boxY + boxHeight - lineH)
                        
                        for i = 1, 8 do
                            setDrawingProp(data.CornerBox[i], "Color", currentBoxColor)
                            setDrawingProp(data.CornerBox[i], "Visible", true)
                        end
                    else
                        for i = 1, 8 do setDrawingProp(data.CornerBox[i], "Visible", false) end
                        setDrawingProp(data.Box, "Position", v2(boxX, boxY))
                        setDrawingProp(data.Box, "Size", v2(boxWidth, boxHeight))
                        setDrawingProp(data.Box, "Color", currentBoxColor)
                        setDrawingProp(data.Box, "Visible", true)
                    end
                else
                    setDrawingProp(data.Box, "Visible", false)
                    for i = 1, 8 do setDrawingProp(data.CornerBox[i], "Visible", false) end
                end

                if nameEnabled then
                    setDrawingProp(data.NameTag, "Text", character.Name)
                    setDrawingProp(data.NameTag, "Position", v2(topPos.X, boxY - 16))
                    setDrawingProp(data.NameTag, "Color", currentNameColor)
                    setDrawingProp(data.NameTag, "Visible", true)
                else
                    setDrawingProp(data.NameTag, "Visible", false)
                end

                local yOffset = bottomPos.Y + 2
                
                if distanceEnabled then
                    local distance = m_floor((camPos - hrp.Position).Magnitude)
                    setDrawingProp(data.DistanceTag, "Text", tostring(distance) .. "m")
                    setDrawingProp(data.DistanceTag, "Position", v2(topPos.X, yOffset))
                    setDrawingProp(data.DistanceTag, "Color", currentNameColor)
                    setDrawingProp(data.DistanceTag, "Visible", true)
                    yOffset = yOffset + 14
                else
                    setDrawingProp(data.DistanceTag, "Visible", false)
                end
                
                if toolEnabled then
                    local tool = character:FindFirstChildOfClass("Tool")
                    setDrawingProp(data.ToolTag, "Text", tool and tool.Name or "None")
                    setDrawingProp(data.ToolTag, "Position", v2(topPos.X, yOffset))
                    setDrawingProp(data.ToolTag, "Color", currentNameColor)
                    setDrawingProp(data.ToolTag, "Visible", true)
                else
                    setDrawingProp(data.ToolTag, "Visible", false)
                end

                local healthPercent = m_clamp(humanoid.Health / (humanoid.MaxHealth > 0 and humanoid.MaxHealth or 100), 0, 1)
                local barWidth = 3
                local barOffset = 5
                local barX = boxX - barOffset - barWidth
                local healthHeight = boxHeight * healthPercent
                local healthColor = c3rgb(255, 0, 0):Lerp(c3rgb(0, 255, 0), healthPercent)

                if healthEnabled then
                    setDrawingProp(data.HealthBarBg, "Position", v2(barX, boxY))
                    setDrawingProp(data.HealthBarBg, "Size", v2(barWidth, boxHeight))
                    setDrawingProp(data.HealthBarBg, "Visible", true)

                    setDrawingProp(data.HealthBar, "Position", v2(barX, boxY + (boxHeight - healthHeight)))
                    setDrawingProp(data.HealthBar, "Size", v2(barWidth, healthHeight))
                    setDrawingProp(data.HealthBar, "Color", healthColor)
                    setDrawingProp(data.HealthBar, "Visible", true)
                else
                    setDrawingProp(data.HealthBarBg, "Visible", false)
                    setDrawingProp(data.HealthBar, "Visible", false)
                end
                
                if healthTextEnabled then
                    setDrawingProp(data.HealthTextTag, "Text", tostring(m_floor(humanoid.Health)) .. " HP")
                    setDrawingProp(data.HealthTextTag, "Position", v2(barX - 18, boxY + (boxHeight - healthHeight) - 6))
                    setDrawingProp(data.HealthTextTag, "Color", healthColor)
                    setDrawingProp(data.HealthTextTag, "Visible", true)
                else
                    setDrawingProp(data.HealthTextTag, "Visible", false)
                end
            else
                setDrawingProp(data.Box, "Visible", false)
                for i = 1, 8 do setDrawingProp(data.CornerBox[i], "Visible", false) end
                setDrawingProp(data.HealthBarBg, "Visible", false)
                setDrawingProp(data.HealthBar, "Visible", false)
                setDrawingProp(data.NameTag, "Visible", false)
                setDrawingProp(data.DistanceTag, "Visible", false)
                setDrawingProp(data.HealthTextTag, "Visible", false)
                setDrawingProp(data.ToolTag, "Visible", false)
            end

            if skeletonEnabled then
                local currentBones = cached.BoneParts
                for i, line in ipairs(data.Skeleton) do
                    local parts = currentBones[i]
                    if parts then
                        local partA, partB = parts[1], parts[2]
                        if partA and partB and partA.Parent and partB.Parent then
                            local posA, onScreenA = currentCamera:WorldToViewportPoint(partA.Position)
                            local posB, onScreenB = currentCamera:WorldToViewportPoint(partB.Position)

                            if onScreenA and onScreenB then
                                line.From = v2(posA.X, posA.Y)
                                line.To = v2(posB.X, posB.Y)
                                setDrawingProp(line, "Color", currentSkeletonColor)
                                setDrawingProp(line, "Visible", true)
                            else
                                setDrawingProp(line, "Visible", false)
                            end
                        else
                            setDrawingProp(line, "Visible", false)
                        end
                    else
                        setDrawingProp(line, "Visible", false)
                    end
                end
            else
                for i = 1, 14 do setDrawingProp(data.Skeleton[i], "Visible", false) end
            end
        else
            hideVisuals(data)
        end
    end
end

t_insert(Connections, RunService.RenderStepped:Connect(function()
    local currentCamera = Workspace.CurrentCamera
    if not currentCamera then return end
    
    local mousePos = UserInputService:GetMouseLocation()
    local tggls = Toggles
    local opts = Options

    if not (tggls and opts) then return end

    if tggls.DisableVisualEffects and tggls.DisableVisualEffects.Value then
        for i = 1, #VISUAL_EFFECTS do
            local effect = Lighting:FindFirstChild(VISUAL_EFFECTS[i])
            if effect and effect.Enabled then
                effect.Enabled = false
            end
        end
    end

    local fovEnabled = tggls.FOVEnabled.Value
    local tracerEnabled = tggls.TracerEnabled.Value
    
    if fovEnabled then
        local outlineEnabled = tggls.FOVOutline.Value
        local filledEnabled = tggls.FOVFilled.Value
        local fovRadius = opts.FOVRadius.Value
        local fovNumSides = opts.FOVNumSides.Value

        setDrawingProp(FOVCircle, "Visible", outlineEnabled)
        setDrawingProp(FOVFilledCircle, "Visible", filledEnabled)

        if outlineEnabled then
            setDrawingProp(FOVCircle, "Position", mousePos)
            setDrawingProp(FOVCircle, "Radius", fovRadius)
            setDrawingProp(FOVCircle, "Thickness", opts.FOVThickness.Value)
            setDrawingProp(FOVCircle, "NumSides", fovNumSides)
            setDrawingProp(FOVCircle, "Color", opts.FOVOutlineColor.Value)
        end

        if filledEnabled then
            setDrawingProp(FOVFilledCircle, "Position", mousePos)
            setDrawingProp(FOVFilledCircle, "Radius", fovRadius)
            setDrawingProp(FOVFilledCircle, "NumSides", fovNumSides)
            setDrawingProp(FOVFilledCircle, "Color", opts.FOVFilledColor.Value)
            setDrawingProp(FOVFilledCircle, "Transparency", opts.FOVFilledTransparency.Value)
        end
    else
        setDrawingProp(FOVCircle, "Visible", false)
        setDrawingProp(FOVFilledCircle, "Visible", false)
    end

    if tracerEnabled then
        local targetPos = getClosestCharacterToMouse(mousePos, currentCamera)
        if targetPos then
            setDrawingProp(TracerLine, "Visible", true)
            setDrawingProp(TracerLine, "From", mousePos)
            setDrawingProp(TracerLine, "To", targetPos)
            setDrawingProp(TracerLine, "Color", opts.TracerColor.Value)
            setDrawingProp(TracerLine, "Thickness", opts.TracerThickness.Value)
        else
            setDrawingProp(TracerLine, "Visible", false)
        end
    else
        setDrawingProp(TracerLine, "Visible", false)
    end

    local camPos = currentCamera.CFrame.Position
    updateVisualsForCache(ESPCache, currentCamera, camPos, false)
    updateVisualsForCache(NPC_ESPCache, currentCamera, camPos, true)
end))

local oldIndex
oldIndex = hookmetamethod(game, "__index", newcclosure(function(self, key)
    if checkcaller() or (Library and Library.Unloaded) then
        return oldIndex(self, key)
    end
    if typeof(self) == "Instance" then
        if key == "Value" then
            if self.Name == "BulletSpread" and Toggles and Toggles.NoSpread and Toggles.NoSpread.Value then
                local realVal = oldIndex(self, key)
                if type(realVal) == "number" then return 0 end
                if typeof(realVal) == "Vector3" then return v3(0, 0, 0) end
                if typeof(realVal) == "Vector2" then return v2(0, 0) end
                return 0
            elseif self.Name == "Recoil" and Toggles and Toggles.NoRecoil and Toggles.NoRecoil.Value then
                local realVal = oldIndex(self, key)
                if type(realVal) == "number" then return 0 end
                if typeof(realVal) == "Vector3" then return v3(0, 0, 0) end
                if typeof(realVal) == "Vector2" then return v2(0, 0) end
                return 0
            end
        end
    end
    return oldIndex(self, key)
end))

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(...)
    if checkcaller() or (Library and Library.Unloaded) then
        return oldNamecall(...)
    end

    local args = {...}
    local self = args[1]
    local Method = getnamecallmethod()
    
    if typeof(self) == "Instance" then
        if (Method == "GetAttribute" or Method == "getAttribute") then
            if #args >= 2 and args[2] == "BulletSpread" and Toggles and Toggles.NoSpread and Toggles.NoSpread.Value then
                local realVal = oldNamecall(...)
                if type(realVal) == "number" then return 0 end
                if typeof(realVal) == "Vector3" then return v3(0, 0, 0) end
                if typeof(realVal) == "Vector2" then return v2(0, 0) end
                return 0
            end
            if #args >= 2 and args[2] == "Recoil" and Toggles and Toggles.NoRecoil and Toggles.NoRecoil.Value then
                local realVal = oldNamecall(...)
                if type(realVal) == "number" then return 0 end
                if typeof(realVal) == "Vector3" then return v3(0, 0, 0) end
                if typeof(realVal) == "Vector2" then return v2(0, 0) end
                return 0
            end
        elseif Method == "BindToRenderStep" and #args >= 2 and args[2] == "CameraRecoil" and Toggles and Toggles.NoRecoil and Toggles.NoRecoil.Value then
            return
        elseif Method == "Fire" and self.Name == "CameraShake" and Toggles and Toggles.NoRecoil and Toggles.NoRecoil.Value then
            return
        elseif Method == "FireServer" and self.Name == "GunEvent" and #args >= 3 and args[2] == "FireShot" and type(args[3]) == "table" then
            local tggls = Toggles
            local opts = Options
            if tggls and opts then
                local overriden = false
                local shouldSilentAim = true
                if tggls.RandomizeBullets and tggls.RandomizeBullets.Value then
                    if not CalculateChance(opts.MultiBulletChance.Value) then
                        shouldSilentAim = false
                    end
                end

                if shouldSilentAim then
                    local currentCamera = Workspace.CurrentCamera
                    local mousePos = UserInputService:GetMouseLocation()
                    local _, HitPart, HitPos, isNPC = getClosestCharacterToMouse(mousePos, currentCamera)
                    
                    if HitPart and HitPos then
                        local chance = isNPC and opts.NPCHitchance.Value or opts.Hitchance.Value
                        local bypassDistance = isNPC and opts.NPCCloseRangeBypass.Value or opts.CloseRangeBypass.Value
                        local playerChar = LocalPlayer.Character
                        
                        if playerChar then
                            local hrp = playerChar:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                local distance3D = (hrp.Position - HitPos).Magnitude
                                if distance3D <= bypassDistance then
                                    chance = 100
                                end
                            end
                        end
                        
                        if CalculateChance(chance) then
                            args[3].HitPart = HitPart
                            args[3].HitPos = HitPos
                            overriden = true
                        end
                    end
                end
                
                if not overriden and tggls.NoSpread and tggls.NoSpread.Value then
                    local origin = args[3].Origin
                    local mouse = LocalPlayer:GetMouse()
                    if origin and mouse then
                        local dir = (mouse.Hit.Position - origin).Unit * 1000
                        noSpreadRayParams.FilterDescendantsInstances = {LocalPlayer.Character, Workspace:FindFirstChild("Debris")}
                        
                        local result = Workspace:Raycast(origin, dir, noSpreadRayParams)
                        if result then
                            args[3].HitPart = result.Instance
                            args[3].HitPos = result.Position
                            args[3].HitNormal = result.Normal
                        else
                            args[3].HitPart = nil
                            args[3].HitPos = origin + dir
                            args[3].HitNormal = v3(0, 1, 0)
                        end
                    end
                end
                
                if setnamecallmethod then setnamecallmethod(Method) end
                return oldNamecall(table.unpack(args))
            end
        end
    end
    
    return oldNamecall(...)
end))

task.spawn(function()
    local success, CameraShaker = pcall(require, ReplicatedStorage:WaitForChild("ClientModules", 5):WaitForChild("CameraShaker", 5))
    if not success or not CameraShaker then return end
    
    local oldUpdate
    oldUpdate = hookfunction(CameraShaker.Update, function(self, ...)
        if Library and Library.Unloaded then
            return oldUpdate(self, ...)
        end
        if Toggles and Toggles.DisableCameraShake and Toggles.DisableCameraShake.Value then
            return cf_new()
        end
        return oldUpdate(self, ...)
    end)
end)

task.spawn(function()
    local Interactables = ReplicatedStorage:WaitForChild("Interactables", 5)
    
    local function modifyInteractables()
        if not Interactables then return end
        for _, module in ipairs(Interactables:GetDescendants()) do
            if module:IsA("ModuleScript") then
                task.spawn(function()
                    local success, result = pcall(require, module)
                    if success and type(result) == "table" and result.HoldDuration then
                        if Toggles and Toggles.InstantInteract and Toggles.InstantInteract.Value then
                            if not result.OriginalHoldDuration then
                                result.OriginalHoldDuration = result.HoldDuration
                            end
                            result.HoldDuration = 0
                        else
                            if result.OriginalHoldDuration then
                                result.HoldDuration = result.OriginalHoldDuration
                            end
                        end
                    end
                end)
            end
        end
    end

    if Toggles and Toggles.InstantInteract then
        Toggles.InstantInteract:OnChanged(modifyInteractables)
    end

    if Interactables then
        t_insert(Connections, Interactables.DescendantAdded:Connect(function(descendant)
            if descendant:IsA("ModuleScript") and Toggles and Toggles.InstantInteract and Toggles.InstantInteract.Value then
                task.wait(0.5)
                local success, result = pcall(require, descendant)
                if success and type(result) == "table" and result.HoldDuration then
                    if not result.OriginalHoldDuration then
                        result.OriginalHoldDuration = result.HoldDuration
                    end
                    result.HoldDuration = 0
                end
            end
        end))
    end
end)

local function setupStamina(character)
    task.spawn(function()
        local animate = character:WaitForChild("Animate", 5)
        if not animate then return end
        local staminaValue = animate:WaitForChild("Stamina", 5)
        if not staminaValue then return end
        
        local function syncStamina()
            if Toggles and Toggles.InfiniteStamina and Toggles.InfiniteStamina.Value then
                local maxStamina = staminaValue:GetAttribute("MaxStamina")
                if maxStamina and staminaValue.Value ~= maxStamina then
                    staminaValue.Value = maxStamina
                end
            end
        end
        
        syncStamina()
        t_insert(Connections, staminaValue:GetAttributeChangedSignal("MaxStamina"):Connect(syncStamina))
        t_insert(Connections, staminaValue:GetPropertyChangedSignal("Value"):Connect(syncStamina))
    end)
end

if LocalPlayer.Character then
    setupStamina(LocalPlayer.Character)
end
t_insert(Connections, LocalPlayer.CharacterAdded:Connect(setupStamina))

task.spawn(function()
    local playerConfig = LocalPlayer:WaitForChild("PlayerConfig", 5)
    if not playerConfig then return end
    local ammoFolder = playerConfig:WaitForChild("Ammo", 5)
    if not ammoFolder then return end
    local ammoTypes = {"Shotgun", "Pistol", "Rifle", "SMG"}

    local function setupAmmoLock(ammoValue)
        local function syncAmmo()
            if Toggles and Toggles.InfiniteAmmo and Toggles.InfiniteAmmo.Value and Options and Options.AmmoTypeSelect and Options.AmmoTypeSelect.Value[ammoValue.Name] then
                local maxAmmo = ammoValue:GetAttribute("MaxAmmo")
                if maxAmmo and ammoValue.Value ~= maxAmmo then
                    ammoValue.Value = maxAmmo
                end
            end
        end
        syncAmmo()
        t_insert(Connections, ammoValue:GetAttributeChangedSignal("MaxAmmo"):Connect(syncAmmo))
        t_insert(Connections, ammoValue:GetPropertyChangedSignal("Value"):Connect(syncAmmo))
    end

    for _, ammoName in ipairs(ammoTypes) do
        local ammoValue = ammoFolder:WaitForChild(ammoName, 5)
        if ammoValue then
            setupAmmoLock(ammoValue)
        end
    end
end)

task.spawn(function()
    local playerData = LocalPlayer:WaitForChild("PlayerData", 5)
    if not playerData then return end

    local function maintainThirst()
        if Toggles and Toggles.AutoThirst and Toggles.AutoThirst.Value then
            if playerData:GetAttribute("Thirst") ~= 100 then
                playerData:SetAttribute("Thirst", 100)
            end
        end
    end

    local function maintainHunger()
        if Toggles and Toggles.AutoHunger and Toggles.AutoHunger.Value then
            if playerData:GetAttribute("Hunger") ~= 100 then
                playerData:SetAttribute("Hunger", 100)
            end
        end
    end

    maintainThirst()
    maintainHunger()
    
    t_insert(Connections, playerData:GetAttributeChangedSignal("Thirst"):Connect(maintainThirst))
    t_insert(Connections, playerData:GetAttributeChangedSignal("Hunger"):Connect(maintainHunger))
    
    if Toggles then
        if Toggles.AutoThirst then Toggles.AutoThirst:OnChanged(maintainThirst) end
        if Toggles.AutoHunger then Toggles.AutoHunger:OnChanged(maintainHunger) end
    end
end)

local weightBenchDebounce = 0
t_insert(Connections, RunService.Heartbeat:Connect(function()
    local now = os.clock()
    
    if Toggles and Toggles.AutoWeightBench and Toggles.AutoWeightBench.Value then
        if now - weightBenchDebounce >= 0.25 then
            local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
            local minigame = playerGui and playerGui:FindFirstChild("WeightBenchMinigame")
            if minigame then
                local bar = minigame:FindFirstChild("Bar")
                local goal = bar and bar:FindFirstChild("Goal")
                local slider = bar and bar:FindFirstChild("Slider")
                if goal and slider then
                    local targetY = goal.Position.Y.Scale
                    local currentSliderY = slider.Position.Y.Scale
                    if m_abs(currentSliderY - targetY) <= 0.02 then
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, false)
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, false)
                        weightBenchDebounce = now
                    end
                end
            end
        end
    end
    
    if Toggles then
        local playerConfig = LocalPlayer:FindFirstChild("PlayerConfig")
        local movementVariables = playerConfig and playerConfig:FindFirstChild("MovementVariables")
        if movementVariables then
            if Toggles.CustomWalkSpeed and Toggles.CustomWalkSpeed.Value then
                local ws = tonumber(Options.WalkSpeedValue.Value)
                if ws and movementVariables:GetAttribute("WalkSpeed") ~= ws then
                    movementVariables:SetAttribute("WalkSpeed", ws)
                end
            end
            if Toggles.CustomSprintSpeed and Toggles.CustomSprintSpeed.Value then
                local ss = tonumber(Options.SprintSpeedValue.Value)
                if ss and movementVariables:GetAttribute("SprintSpeed") ~= ss then
                    movementVariables:SetAttribute("SprintSpeed", ss)
                end
            end
        end
    end
end))

SaveManager:LoadAutoloadConfig()

Library:OnUnload(function()
    for _, conn in ipairs(Connections) do
        conn:Disconnect()
    end
    
    if FOVCircle then FOVCircle:Remove() end
    if FOVFilledCircle then FOVFilledCircle:Remove() end
    if TracerLine then TracerLine:Remove() end
    
    if fullbrightConnection then
        fullbrightConnection:Disconnect()
    end
    
    for player, _ in pairs(ESPCache) do
        removeESPData(ESPCache, player)
    end

    for npc, _ in pairs(NPC_ESPCache) do
        removeESPData(NPC_ESPCache, npc)
    end

    if OriginalLighting.Brightness then
        Lighting.Brightness = OriginalLighting.Brightness
        Lighting.ClockTime = OriginalLighting.ClockTime
        Lighting.FogEnd = OriginalLighting.FogEnd
        Lighting.GlobalShadows = OriginalLighting.GlobalShadows
        Lighting.OutdoorAmbient = OriginalLighting.OutdoorAmbient
    end
    
    Library.Unloaded = true
end)
