if getgenv()._UnloadPreviousInstance then
    pcall(getgenv()._UnloadPreviousInstance)
end

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/refs/heads/main/Library.lua"))()
local ThemeManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/definitionful/Roblox/refs/heads/main/Napoleonic%20Wars/ThemeManager"))()
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/refs/heads/main/addons/SaveManager.lua"))()

getgenv()._UnloadPreviousInstance = function()
    if Library and not Library.Unloaded then
        Library:Unload()
    end
end

local Workspace = game:GetService("Workspace")
local Terrain = Workspace.Terrain
local CurrentCamera = Workspace.CurrentCamera
local RunService = game:GetService("RunService")

local TerrainConnection
local CameraConnection
local TerrainDescendantConnections = {}
local CameraDescendantConnections = {}

local combatModule = nil
local origGetMisfired, origCannonPass, origBulletPass

for _, v in pairs(getgc(true)) do
    if type(v) == "table" and rawget(v, "getMisfired") and rawget(v, "bulletPass") and rawget(v, "cannonPassMoraleShock") then
        combatModule = v
        origGetMisfired = v.getMisfired
        origCannonPass = v.cannonPassMoraleShock
        origBulletPass = v.bulletPass
        break
    end
end

if not combatModule and getloadedmodules then
    for _, mod in pairs(getloadedmodules()) do
        if typeof(mod) == "Instance" and mod:IsA("ModuleScript") then
            local success, ret = pcall(require, mod)
            if success and type(ret) == "table" and rawget(ret, "getMisfired") then
                combatModule = ret
                origGetMisfired = ret.getMisfired
                origCannonPass = ret.cannonPassMoraleShock
                origBulletPass = ret.bulletPass
                break
            end
        end
    end
end

local camShakers = {}
local shakeClasses = {}

for _, obj in pairs(getgc(true)) do
    if type(obj) == "table" then
        if rawget(obj, "_camShakeInstances") and rawget(obj, "Update") then
            table.insert(camShakers, {instance = obj, origUpdate = obj.Update})
        end
        if rawget(obj, "UpdateShake") then
            table.insert(shakeClasses, {instance = obj, origUpdateShake = obj.UpdateShake})
        end
    end
end

local function neutralizeVisual(object)
    if object:IsA("ParticleEmitter") then
        object.Enabled = false
        object.Rate = 0
        task.defer(function()
            object:Destroy()
        end)
    elseif object:IsA("Light") then
        task.defer(function()
            object:Destroy()
        end)
    end
end

local function monitorTerrainChild(child)
    if child:IsA("Attachment") then
        for _, descendant in ipairs(child:GetDescendants()) do
            neutralizeVisual(descendant)
        end
        table.insert(TerrainDescendantConnections, child.DescendantAdded:Connect(neutralizeVisual))
    end
end

local function monitorCameraChild(child)
    if child.Name == "CombatScreenEffectsPart" or child:IsA("Attachment") then
        for _, descendant in ipairs(child:GetDescendants()) do
            neutralizeVisual(descendant)
        end
        table.insert(CameraDescendantConnections, child.DescendantAdded:Connect(neutralizeVisual))
    end
end

local Window = Library:CreateWindow({
    Title      = 'Napoleonic Wars',
    Center     = true,
    AutoShow   = true,
    TabPadding = 8,
    MenuFadeTime = 0.2
})

local Tabs = {
    Combat = Window:AddTab('Combat'),
    Visuals = Window:AddTab('Visuals'),
    Misc = Window:AddTab('Misc'),
    Settings = Window:AddTab('Settings')
}

local WeaponGroup = Tabs.Misc:AddLeftGroupbox('Weapon')
local PlayerGroup = Tabs.Misc:AddRightGroupbox('Player')
local MenuGroup = Tabs.Settings:AddLeftGroupbox('Menu')

WeaponGroup:AddToggle('CleanTerrain', { Text = 'Clean Terrain Visuals', Default = false }):OnChanged(function()
    if Toggles.CleanTerrain.Value then
        for _, child in ipairs(Terrain:GetChildren()) do
            monitorTerrainChild(child)
        end
        TerrainConnection = Terrain.ChildAdded:Connect(monitorTerrainChild)
    else
        if TerrainConnection then
            TerrainConnection:Disconnect()
            TerrainConnection = nil
        end
        for _, conn in ipairs(TerrainDescendantConnections) do
            conn:Disconnect()
        end
        table.clear(TerrainDescendantConnections)
    end
end)

WeaponGroup:AddToggle('CleanCamera', { Text = 'Clean Camera Visuals', Default = false }):OnChanged(function()
    if Toggles.CleanCamera.Value then
        for _, child in ipairs(CurrentCamera:GetChildren()) do
            monitorCameraChild(child)
        end
        CameraConnection = CurrentCamera.ChildAdded:Connect(monitorCameraChild)
    else
        if CameraConnection then
            CameraConnection:Disconnect()
            CameraConnection = nil
        end
        for _, conn in ipairs(CameraDescendantConnections) do
            conn:Disconnect()
        end
        table.clear(CameraDescendantConnections)
    end
end)

WeaponGroup:AddToggle('AntiMisfire', { Text = 'Anti-Misfire', Default = false }):OnChanged(function()
    if combatModule then
        if Toggles.AntiMisfire.Value then
            combatModule.getMisfired = function() return false, false end
        else
            combatModule.getMisfired = origGetMisfired
        end
    end
end)

PlayerGroup:AddToggle('AntiSuppression', { Text = 'Anti-Suppression', Default = false }):OnChanged(function()
    if combatModule then
        if Toggles.AntiSuppression.Value then
            combatModule.cannonPassMoraleShock = function() end
            combatModule.bulletPass = function() end
        else
            combatModule.cannonPassMoraleShock = origCannonPass
            combatModule.bulletPass = origBulletPass
        end
    end
end)

local camShakeTask
PlayerGroup:AddToggle('NoCameraShake', { Text = 'No Camera Shake', Default = false }):OnChanged(function()
    local state = Toggles.NoCameraShake.Value
    
    for _, shaker in ipairs(camShakers) do
        if state then
            shaker.instance._camShakeInstances = {}
            shaker.instance.Update = function() return CFrame.new() end
        else
            shaker.instance.Update = shaker.origUpdate
        end
    end
    
    for _, shakerClass in ipairs(shakeClasses) do
        if state then
            shakerClass.instance.UpdateShake = function() return Vector3.new(0, 0, 0) end
        else
            shakerClass.instance.UpdateShake = shakerClass.origUpdateShake
        end
    end
    
    if state then
        camShakeTask = task.spawn(function()
            while task.wait(0.5) do
                pcall(function()
                    RunService:UnbindFromRenderStep("CameraShaker")
                end)
            end
        end)
    else
        if camShakeTask then
            task.cancel(camShakeTask)
            camShakeTask = nil
        end
    end
end)

MenuGroup:AddToggle('WatermarkToggle', { Text = 'Watermark', Default = false }):OnChanged(function()
    Library:SetWatermarkVisibility(Toggles.WatermarkToggle.Value)
end)

MenuGroup:AddToggle('KeybindsToggle', { Text = 'Keybinds', Default = false }):OnChanged(function()
    Library.KeybindFrame.Visible = Toggles.KeybindsToggle.Value
end)

Library:SetWatermark('Napoleonic Wars Client')
Library:SetWatermarkVisibility(false)

ThemeManager:SetLibrary(Library)
SaveManager:SetLibrary(Library)
ThemeManager:SetFolder('NapoleonicWarsConfig')
SaveManager:SetFolder('NapoleonicWarsConfig')
SaveManager:IgnoreThemeSettings()
ThemeManager:ApplyToTab(Tabs.Settings)
SaveManager:BuildConfigSection(Tabs.Settings)

Library:OnUnload(function()
    if TerrainConnection then TerrainConnection:Disconnect() end
    if CameraConnection then CameraConnection:Disconnect() end
    
    for _, conn in ipairs(TerrainDescendantConnections) do conn:Disconnect() end
    for _, conn in ipairs(CameraDescendantConnections) do conn:Disconnect() end
    
    if camShakeTask then task.cancel(camShakeTask) end
    
    if combatModule then
        combatModule.getMisfired = origGetMisfired
        combatModule.cannonPassMoraleShock = origCannonPass
        combatModule.bulletPass = origBulletPass
    end
    
    for _, shaker in ipairs(camShakers) do
        shaker.instance.Update = shaker.origUpdate
    end
    
    for _, shakerClass in ipairs(shakeClasses) do
        shakerClass.instance.UpdateShake = shakerClass.origUpdateShake
    end
    
    Library.Unloaded = true
end)
